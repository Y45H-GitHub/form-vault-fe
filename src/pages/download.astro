---
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import Hero from '../components/Hero.astro';
---

<Layout title="Download" description="Download FormVault for Windows. One installer, about 12 MB, no admin rights required.">
	<Hero eyebrow="Download" title="Get FormVault for Windows." lead="One installer. About 12 MB. Runs quietly in the system tray." />

	<Section class="pb-16">
		<div class="mx-auto max-w-2xl rounded-xl border border-border bg-card p-8">
			<div class="flex flex-col items-center text-center">
				<a
					href="#"
					aria-label="Download FormVault installer for Windows"
					class="inline-flex h-12 items-center gap-2 rounded-md bg-primary px-6 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary-hover"
				>
					<svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor" aria-hidden="true">
						<path d="M3 5.4 10.5 4v7.5H3V5.4Zm0 7.1h7.5V20L3 18.6v-6.1Zm8.5-8.6L21 2.5V11.5h-9.5V3.9Zm0 8.6H21V21.5l-9.5-1.4V12.5Z" />
					</svg>
					Download for Windows
				</a>
				<div class="mt-3 text-xs text-subtle">Version 1.0 &middot; Windows 10 or later &middot; Placeholder link</div>
			</div>

			<div class="mt-8 grid gap-6 border-t border-border pt-6 sm:grid-cols-2">
				<div>
					<div class="text-xs font-medium uppercase tracking-wider text-subtle">System requirements</div>
					<ul class="mt-2 space-y-1 text-sm text-muted-foreground">
						<li>Windows 10 (build 1809) or later</li>
						<li>64-bit processor</li>
						<li>~50 MB free disk space</li>
						<li>No admin rights required</li>
					</ul>
				</div>
				<div>
					<div class="text-xs font-medium uppercase tracking-wider text-subtle">Install in three steps</div>
					<ol class="mt-2 space-y-1 text-sm text-muted-foreground">
						<li>1. Download and run the installer.</li>
						<li>2. Pick a location; approve the SmartScreen prompt.</li>
						<li>3. FormVault docks in the system tray. Press the hotkey.</li>
					</ol>
				</div>
			</div>
		</div>

		<p class="mt-6 text-center text-xs text-subtle">
			macOS and Linux are not supported today. See the <a href="/faq" class="text-primary underline-offset-4 hover:underline">FAQ</a> for
			details.
		</p>
	</Section>
</Layout>
