---
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import PopupMockup from '../components/PopupMockup.astro';
import PopupArt from '../components/PopupMockup.astro';
import VaultArt from '../components/VaultManagerMockup.astro';
import CodeExpansionDemo from '../components/CodeExpansionDemo.astro';
import { RELEASE_VERSION, RELEASE_SIZE_MB } from '../constants/release';

const highlights = [
	{
		title: 'One hotkey, anywhere',
		body: 'A global shortcut opens a search popup at your cursor. Any app, any focused field, any time.'
	},
	{
		title: 'Any field, any country',
		body: 'PAN, Aadhaar, GST, IFSC and UPI ship as defaults because that’s where the friction is worst - not because the vault is India-only. Rename, remove, or add any field: a VAT number or SSN works the same way.'
	},
	{
		title: 'Local-first, always',
		body: 'Your vault is a file on your machine. No account, no cloud, no telemetry over your data.'
	},
	{
		title: 'Precise, not flashy',
		body: 'Fast keyboard-driven UI. Masked values by default. Follows your Windows light or dark theme.'
	}
];

const useCases = [
	{
		title: 'Service centre & CSC operators',
		body: 'Filling PAN, Aadhaar, and bank forms for someone else, over and over. Switch profiles per client and never miswrite a number twice.'
	},
	{
		title: 'Insurance & loan agents',
		body: 'Client paperwork across a dozen disconnected portals - old desktop banking software included, where browser autofill can’t reach. Type once, paste identically everywhere.'
	},
	{
		title: 'Freelancers & small business owners',
		body: 'GST, bank details, and business info for marketplace seller onboarding, vendor forms, and invoices - correct every time, no mismatch delays.'
	},
	{
		title: 'Anyone who retypes the same thing daily',
		body: 'Email signatures, addresses, code snippets, canned replies. Not just structured fields - anything you find yourself typing twice.'
	}
];

const steps = [
	{
		n: '01',
		title: 'Save your fields once',
		body: 'Open the Vault Manager and add PAN, Aadhaar, GST, bank details, addresses, whatever you type often. Group them by category and profile.'
	},
	{
		n: '02',
		title: 'Press the hotkey',
		body: 'Anywhere in Windows, hit Ctrl + Shift + Space. A search popup appears at your cursor. Start typing to filter.'
	},
	{
		n: '03',
		title: 'Paste and move on',
		body: 'Enter copies the value and pastes into the focused field when it can. Or type a shortcut like !pan to expand inline without opening the popup.'
	}
];


---

<Layout
	title="Retrivo - Your personal data, one keystroke away"
	description="A local-first Windows tray app that recalls anything you retype - PAN, GST, addresses, email templates - anywhere: bank apps, government portals, PDFs, Excel. Faster than browser autofill, and it works for any country's fields, not just India's."
>
	<section class="relative">
		<div class="pointer-events-none absolute inset-0 grid-bg opacity-60" aria-hidden="true"></div>
		<div class="mx-auto max-w-4xl px-6 pt-24 pb-16 text-center md:pt-32">
			<div class="mb-6 inline-flex items-center gap-2 rounded-full border border-border bg-surface px-3 py-1 text-[11px] text-muted-foreground">
				<span class="h-1.5 w-1.5 rounded-full bg-primary"></span>
				Windows &middot; {RELEASE_VERSION} &middot; Local-first &middot; Open source
			</div>
			<h1 class="text-4xl font-semibold leading-[1.05] tracking-tight text-foreground md:text-6xl">
				One shortcut.<br />Everything you retype.
			</h1>
			<p class="mx-auto mt-5 max-w-2xl text-base leading-relaxed text-muted-foreground md:text-lg">
				There's no server - your details live only on this machine, encrypted with your Windows account.
				Search and paste anywhere in Windows - bank apps, government portals, PDFs, Excel - faster and more
				reliably than browser autofill. Not just forms: emails, addresses, code snippets, anything you
				find yourself typing twice.
			</p>
			<div class="mt-8 flex flex-wrap items-center justify-center gap-3">
				<a
					href="/download"
					class="inline-flex h-10 items-center gap-2 rounded-md bg-primary px-5 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary-hover"
				>
					Download for Windows
				</a>
				<a
					href="/features"
					class="inline-flex h-10 items-center gap-2 rounded-md border border-border bg-surface px-5 text-sm font-medium text-foreground transition-colors hover:border-foreground/30"
				>
					See how it works
				</a>
			</div>
			<div class="mt-4">
				<a href="/security" class="text-xs text-muted-foreground underline-offset-4 hover:text-foreground hover:underline">
					See exactly how your data is protected &rarr;
				</a>
			</div>
			<div class="mt-6 flex items-center justify-center gap-2 text-xs text-subtle">
				<span>Press</span>
				<span class="kbd">Ctrl</span>
				<span class="kbd">⇧</span>
				<span class="kbd">Space</span>
				<span>anywhere in Windows</span>
			</div>
		</div>
	</section>

	<Section class="pb-24">
		<div class="relative rounded-2xl border border-border bg-card/60 p-4 md:p-10">
			<div class="absolute inset-x-0 -top-px mx-auto h-px w-1/2 bg-gradient-to-r from-transparent via-primary/40 to-transparent"></div>
			<div class="mx-auto max-w-2xl">
				<PopupMockup />
			</div>
			<p class="mt-6 text-center text-xs text-subtle">The popup, rendered from real UI. A screen recording lives here.</p>
		</div>
	</Section>

	<Section>
		<div class="mb-10 flex items-end justify-between">
			<div>
				<div class="text-xs font-medium uppercase tracking-wider text-primary">Highlights</div>
				<h2 class="mt-2 text-2xl font-semibold tracking-tight md:text-3xl">Fast where it matters. Quiet everywhere else.</h2>
			</div>
			<a href="/features" class="hidden text-sm text-muted-foreground transition-colors hover:text-foreground md:inline-flex">
				All features &rarr;
			</a>
		</div>
		<div class="grid gap-px overflow-hidden rounded-xl border border-border bg-border md:grid-cols-2 lg:grid-cols-4">
			{
				highlights.map((item) => (
					<div class="bg-card p-6">
						<h3 class="text-sm font-semibold text-foreground">{item.title}</h3>
						<p class="mt-2 text-sm leading-relaxed text-muted-foreground">{item.body}</p>
					</div>
				))
			}
		</div>
	</Section>

	<Section class="mt-24">
		<div class="mb-12 max-w-2xl">
			<div class="text-xs font-medium uppercase tracking-wider text-primary">How it works</div>
			<h2 class="mt-2 text-2xl font-semibold tracking-tight md:text-3xl">Three steps. Then never again.</h2>
		</div>
		<div class="space-y-16">
			{
				steps.map((step, i) => (
					<div class:list={['grid items-center gap-8 md:grid-cols-2', i % 2 === 1 ? 'md:[&>*:first-child]:order-2' : '']}>
						<div class="rounded-xl border border-border bg-card p-4">
							{step.n === '01' && <VaultArt />}
							{step.n === '02' && <PopupArt />}
							{step.n === '03' && <CodeExpansionDemo />}
						</div>
						<div>
							<div class="font-mono text-xs text-primary">{step.n}</div>
							<h3 class="mt-2 text-xl font-semibold text-foreground">{step.title}</h3>
							<p class="mt-3 text-sm leading-relaxed text-muted-foreground">{step.body}</p>
						</div>
					</div>
				))
			}
		</div>
	</Section>

	<Section class="mt-24">
		<div class="mb-12 max-w-2xl">
			<div class="text-xs font-medium uppercase tracking-wider text-primary">Use cases</div>
			<h2 class="mt-2 text-2xl font-semibold tracking-tight md:text-3xl">Who this is actually for.</h2>
			<p class="mt-3 text-sm leading-relaxed text-muted-foreground">
				Not just one job. Anyone typing the same details into more places than they'd like.
			</p>
		</div>
		<div class="grid gap-px overflow-hidden rounded-xl border border-border bg-border md:grid-cols-2">
			{
				useCases.map((item) => (
					<div class="bg-card p-6">
						<h3 class="text-sm font-semibold text-foreground">{item.title}</h3>
						<p class="mt-2 text-sm leading-relaxed text-muted-foreground">{item.body}</p>
					</div>
				))
			}
		</div>
	</Section>

	<Section class="mt-24">
		<div class="relative overflow-hidden rounded-2xl border border-border bg-card p-10 text-center md:p-14">
			<div class="pointer-events-none absolute inset-0 grid-bg opacity-40" aria-hidden="true"></div>
			<div class="relative">
				<h2 class="text-2xl font-semibold tracking-tight md:text-3xl">Stop retyping. Start pasting.</h2>
				<p class="mx-auto mt-3 max-w-lg text-sm text-muted-foreground">About {RELEASE_SIZE_MB}. Windows 10 or later. Free while in early access.</p>
				<div class="mt-6">
					<a
						href="/download"
						class="inline-flex h-10 items-center rounded-md bg-primary px-5 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary-hover"
					>
						Download for Windows
					</a>
				</div>
			</div>
		</div>
	</Section>
</Layout>
