---
const results = [
	{ cat: 'Financial', label: 'PAN Number', value: 'ABCDE••••F', active: true },
	{ cat: 'Financial', label: 'GST Number', value: '27AAPFU••••Z1ZV', active: false },
	{ cat: 'Financial', label: 'Bank Account', value: '•••• 4471 · HDFC', active: false },
	{ cat: 'Personal', label: 'Aadhaar Number', value: '•••• •••• 2093', active: false },
	{ cat: 'Personal', label: 'Mobile Number', value: '+91 98••• ••432', active: false }
];
---

<div class="w-full rounded-xl border border-border bg-card shadow-[0_30px_80px_-30px_rgba(0,0,0,0.7)]">
	<div class="flex items-center gap-2 border-b border-border px-3 py-2.5">
		<svg viewBox="0 0 24 24" class="h-4 w-4 text-subtle" fill="none" stroke="currentColor" stroke-width="2">
			<circle cx="11" cy="11" r="7" />
			<path d="m20 20-3.5-3.5" stroke-linecap="round" />
		</svg>
		<input readonly value="pan" class="flex-1 bg-transparent text-sm text-foreground outline-none placeholder:text-subtle" />
		<span class="kbd">Ctrl</span>
		<span class="kbd">⇧</span>
		<span class="kbd">Space</span>
	</div>
	<ul class="max-h-80 overflow-hidden py-1 text-sm">
		{
			results.map((item) => (
				<li
					class:list={[
						'mx-1 flex items-center gap-3 rounded-md px-3 py-2',
						item.active ? 'bg-primary/10 text-foreground ring-1 ring-primary/30' : 'text-muted-foreground'
					]}
				>
					<span class:list={['w-16 shrink-0 text-[10px] font-medium uppercase tracking-wider', item.active ? 'text-primary' : 'text-subtle']}>
						{item.cat}
					</span>
					<span class:list={item.active ? 'text-foreground' : ''}>{item.label}</span>
					<span class="ml-auto font-mono text-xs text-subtle">{item.value}</span>
					{item.active && (
						<span class="ml-2 rounded border border-primary/40 bg-primary/10 px-1.5 py-0.5 font-mono text-[10px] text-primary">↵</span>
					)}
				</li>
			))
		}
	</ul>
	<div class="flex items-center justify-between border-t border-border px-3 py-2 text-[11px] text-subtle">
		<span>5 matches</span>
		<span class="flex items-center gap-2">
			<span class="kbd">↑</span>
			<span class="kbd">↓</span>
			<span>navigate</span>
			<span class="kbd ml-2">Esc</span>
			<span>close</span>
		</span>
	</div>
</div>
