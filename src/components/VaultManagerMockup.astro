---
const categories = [
	{ name: 'Personal', count: 8, active: false },
	{ name: 'Financial', count: 12, active: true },
	{ name: 'Business', count: 5, active: false },
	{ name: 'Documents', count: 3, active: false },
	{ name: 'Custom', count: 2, active: false }
];

const fields = [
	{ label: 'PAN Number', value: 'ABCDE1234F', masked: false },
	{ label: 'Aadhaar Number', value: '•••• •••• 2093', masked: true },
	{ label: 'GST Number', value: '27AAPFU0939F1ZV', masked: false },
	{ label: 'Bank Account', value: '•••• •••• 4471', masked: true },
	{ label: 'IFSC Code', value: 'HDFC0000123', masked: false },
	{ label: 'UPI ID', value: 'rahul@okhdfcbank', masked: false }
];
---

<div class="w-full overflow-hidden rounded-xl border border-border bg-card shadow-[0_30px_80px_-30px_rgba(0,0,0,0.7)]">
	<div class="flex items-center gap-2 border-b border-border bg-surface px-3 py-2">
		<span class="h-2.5 w-2.5 rounded-full bg-[#3F3F46]"></span>
		<span class="h-2.5 w-2.5 rounded-full bg-[#3F3F46]"></span>
		<span class="h-2.5 w-2.5 rounded-full bg-[#3F3F46]"></span>
		<span class="ml-3 text-xs text-subtle">Retrivo - Personal profile</span>
	</div>
	<div class="grid grid-cols-[180px_1fr]">
		<aside class="border-r border-border bg-surface p-2">
			<div class="px-2 pb-2 text-[10px] font-medium uppercase tracking-wider text-subtle">Categories</div>
			<ul class="space-y-0.5 text-sm">
				{
					categories.map((cat) => (
						<li
							class:list={[
								'flex items-center justify-between rounded-md px-2 py-1.5',
								cat.active ? 'bg-primary/10 text-foreground ring-1 ring-primary/30' : 'text-muted-foreground'
							]}
						>
							<span>{cat.name}</span>
							<span class="text-xs text-subtle">{cat.count}</span>
						</li>
					))
				}
			</ul>
		</aside>
		<div class="p-4">
			<div class="mb-3 flex items-center justify-between">
				<h3 class="text-sm font-semibold">Financial</h3>
				<span class="text-xs text-subtle">Drag to reorder</span>
			</div>
			<ul class="space-y-1.5">
				{
					fields.map((field) => (
						<li class="flex items-center gap-3 rounded-md border border-border/70 bg-background/40 px-3 py-2 text-sm">
							<svg viewBox="0 0 24 24" class="h-3.5 w-3.5 text-subtle" fill="currentColor">
								<circle cx="9" cy="6" r="1.4" />
								<circle cx="15" cy="6" r="1.4" />
								<circle cx="9" cy="12" r="1.4" />
								<circle cx="15" cy="12" r="1.4" />
								<circle cx="9" cy="18" r="1.4" />
								<circle cx="15" cy="18" r="1.4" />
							</svg>
							<span class="w-32 shrink-0 text-muted-foreground">{field.label}</span>
							<span class="font-mono text-xs text-foreground">{field.value}</span>
							{field.masked && <span class="ml-auto text-[10px] uppercase tracking-wider text-subtle">masked</span>}
						</li>
					))
				}
			</ul>
		</div>
	</div>
</div>
