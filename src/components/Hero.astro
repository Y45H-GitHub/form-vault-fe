---
interface Props {
	eyebrow?: string;
	title: string;
	lead?: string;
}
const { eyebrow, title, lead } = Astro.props;
---

<div class="mx-auto max-w-3xl px-6 pt-20 pb-10 text-center md:pt-28">
	{
		eyebrow && (
			<div class="mb-4 inline-flex items-center gap-2 rounded-full border border-border bg-surface px-3 py-1 text-[11px] font-medium uppercase tracking-wider text-primary">
				{eyebrow}
			</div>
		)
	}
	<h1 class="text-4xl font-semibold tracking-tight md:text-5xl">{title}</h1>
	{lead && <p class="mx-auto mt-4 max-w-2xl text-base leading-relaxed text-muted-foreground">{lead}</p>}
</div>
